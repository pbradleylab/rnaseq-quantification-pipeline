{
    "fastqc": {
        "mem": 1024,
        "threads": 8
    },
    "star": {
        "mem": 1024,
        "threads": 8,
        "read_files": "gunzip -c",
        "type": "BAM Unsorted",
        "quant_mode": "TranscriptomeSAM",
        "gene_counts_strandedness": "unstranded",
        "other": ""
    },
    "fastq_screen": {
        "threads": 8,
        "mem": 1024,
        "subset": 100000,
        "aligner": "bowtie2"
    },
    "multiqc": {
        "mem": 1024
    },
    "strandedness_check": {
        "enabled": "true",
        "mode": "warn",
        "min_fraction": 0.75,
        "min_ratio": 2.0
    },
    "sample_identity": {
        "group_column": "Time",
        "top_variable_features": 5000,
        "min_nearest_correlation": 0.90,
        "same_group_margin": 0.03,
        "duplicate_min_correlation": 0.995,
        "duplicate_max_library_size_difference": 0.05
    },
    "trim_galore": {
        "mem": 1024
    },
    "sortmerna": {
        "mem": 4096,
        "threads": 8,
        "refs": [],
        "extra": ""
    },
    "combine_quants": {
        "mem": 1024
    },
    "kallisto": {
        "mem": 1024,
        "threads": 8
    },
    "featurecounts": {
        "mem": 1024,
        "threads": 8,
        "strandedness": 0,
        "feature_type": "gene",
        "attribute": "ID",
        "extra": ""
    },
    "gunc": {
        "threads": 4,
        "mem": 8192
    },
    "deseq2":{
        "design_formula":"~ Time",
        "reference_in_variable":"0min",
        "variable_to_analyze":"Time",
        "log2fc_threshold": 0.6,
        "padj_threshold": 0.05,
        "label_top_n": 10,
        "transform_method": "vst",
        "min_replicates_per_condition": 2
    }
}
